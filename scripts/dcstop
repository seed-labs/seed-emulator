#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/dc-common.sh"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage: dcstop [output_dir_or_compose_file]

Defaults:
  - target: current directory
  - action: stop
EOF
  exit 0
fi

TARGET="${1:-.}"
COMPOSE_FILE="$(resolve_compose_target "${TARGET}")"
COMPOSE_CMD="$(compose_cmd)"

echo "[dcstop] compose file: ${COMPOSE_FILE}"
${COMPOSE_CMD} -f "${COMPOSE_FILE}" stop

