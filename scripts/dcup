#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/dc-common.sh"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage_dcup
  exit 0
fi

BUILD_FLAG="0"
if [[ "${1:-}" == "--build" ]]; then
  BUILD_FLAG="1"
  shift
fi

TARGET="${1:-.}"
COMPOSE_FILE="$(resolve_compose_target "${TARGET}")"
MAP_PORT="$(default_map_port)"
COMPOSE_CMD="$(compose_cmd)"

echo "[dcup] compose file: ${COMPOSE_FILE}"
echo "[dcup] map port: ${MAP_PORT}"

guard_single_active_baseline "${COMPOSE_FILE}"

maybe_disable_bridge_netfilter

if [[ "${BUILD_FLAG}" == "1" ]]; then
  echo "[dcup] build mode: on"
  SEED_DEMO_MAP_PORT="${MAP_PORT}" ${COMPOSE_CMD} -f "${COMPOSE_FILE}" up -d --build --remove-orphans
else
  SEED_DEMO_MAP_PORT="${MAP_PORT}" ${COMPOSE_CMD} -f "${COMPOSE_FILE}" up -d --no-build --remove-orphans
fi
