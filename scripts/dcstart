#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/dc-common.sh"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage: dcstart [output_dir_or_compose_file]

Defaults:
  - target: current directory
  - action: start
  - map port: SEED_DEMO_MAP_PORT or 18080
EOF
  exit 0
fi

TARGET="${1:-.}"
COMPOSE_FILE="$(resolve_compose_target "${TARGET}")"
MAP_PORT="$(default_map_port)"
COMPOSE_CMD="$(compose_cmd)"

echo "[dcstart] compose file: ${COMPOSE_FILE}"
echo "[dcstart] map port: ${MAP_PORT}"

guard_single_active_baseline "${COMPOSE_FILE}"

maybe_disable_bridge_netfilter

SEED_DEMO_MAP_PORT="${MAP_PORT}" ${COMPOSE_CMD} -f "${COMPOSE_FILE}" start
