#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib.sh"
seed_shortcuts_source_env

usage() {
  cat <<'USAGE'
Usage: k3scompare [profile]
Maps to: scripts/seed_k8s_profile_runner.sh <profile> compare
Note: uses SEED_COMPOSE_DIR (default: ~/lxl_topology/autocoder_test)
USAGE
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

profile="$(seed_shortcuts_profile "${1:-}")"
repo_root="$(seed_shortcuts_repo_root)"
cmd=( "${repo_root}/scripts/seed_k8s_profile_runner.sh" "${profile}" compare )
seed_shortcuts_print_map "k3scompare" "${cmd[@]}"
exec "${cmd[@]}"

