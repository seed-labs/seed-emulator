#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib.sh"
seed_shortcuts_source_env
seed_shortcuts_ensure_kubeconfig

usage() {
  cat <<'USAGE'
Usage: k3sdown [profile]
Maps to: kubectl delete namespace <ns> --ignore-not-found
Note: equivalent to "docker compose down" in spirit (cleans runtime only).
USAGE
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

profile="$(seed_shortcuts_profile "${1:-}")"
namespace="$(seed_shortcuts_resolve_namespace "${profile}")"
if [ -z "${namespace}" ]; then
  seed_shortcuts_die "cannot resolve namespace for profile ${profile} (set SEED_NAMESPACE or run once to generate summary.json)"
fi

cmd=( kubectl delete namespace "${namespace}" --ignore-not-found )
seed_shortcuts_print_map "k3sdown" "${cmd[@]}"
exec "${cmd[@]}"
